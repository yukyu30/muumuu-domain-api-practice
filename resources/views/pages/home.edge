<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>muumuu-domain-api-practice</title>
    @vite(['resources/css/app.css', 'resources/js/app.js'])
  </head>
  <body style="font-family: system-ui, -apple-system, sans-serif; max-width: 720px; margin: 3rem auto; padding: 0 1rem; color: #21201c;">
    <header style="margin-bottom: 2rem;">
      <h1 style="margin: 0 0 0.5rem 0; font-size: 1.6rem;">muumuu-domain-api-practice</h1>
      <p style="margin: 0; color: #63635e; font-size: 0.95rem;">
        ムームードメイン MeAPI で遊ぶ Adonis アプリ。
      </p>
    </header>

    <nav aria-label="主要機能">
      <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem;">
        <li>
          <a
            href="/domains"
            style="display: block; padding: 1rem 1.25rem; border: 1px solid #cfceca; border-radius: 8px; text-decoration: none; color: inherit;"
          >
            <strong style="display: block; font-size: 1.05rem;">あなたのドメイン一覧</strong>
            <span style="display: block; margin-top: 0.25rem; color: #63635e; font-size: 0.9rem;">
              ムームードメインで保有しているドメインを取得・確認・T シャツデザイン生成
            </span>
          </a>
        </li>
      </ul>
    </nav>

    <footer style="margin-top: 3rem; color: #82827c; font-size: 0.8rem;">
      MeAPI docs: <a href="https://muumuu-domain.com/developers/openapi-me.html" style="color: inherit;">muumuu-domain.com/developers/openapi-me.html</a>
    </footer>
  </body>
</html>
